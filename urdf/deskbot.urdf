<?xml version="1.0"?>
<robot name="deskbot">

  <!-- ============================================================ -->
  <!-- BASE LINK (fixed to desk surface)                            -->
  <!-- ============================================================ -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.10 0.20 0.04"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.10 0.20 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
               iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!-- LEFT ARM                                                      -->
  <!-- ============================================================ -->

  <!-- Left arm mount -->
  <link name="left_arm_mount">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="left_base_rotation" type="revolute">
    <parent link="base_link"/>
    <child link="left_arm_mount"/>
    <origin xyz="0.0 0.09 0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.6" upper="2.6" effort="10.0" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Left upper arm -->
  <link name="left_upper_arm">
    <visual>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.13"/>
      </geometry>
      <material name="blue_arm">
        <color rgba="0.2 0.4 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.13"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0"
               iyy="0.0003" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="left_shoulder_pitch" type="revolute">
    <parent link="left_arm_mount"/>
    <child link="left_upper_arm"/>
    <origin xyz="0.0 0.0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="2.6" effort="10.0" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Left forearm pivot link -->
  <link name="left_forearm_pivot">
    <visual>
      <geometry>
        <cylinder radius="0.020" length="0.025"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.020" length="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0"
               iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="left_shoulder_roll" type="revolute">
    <parent link="left_upper_arm"/>
    <child link="left_forearm_pivot"/>
    <origin xyz="0.0 0.0 0.13" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.6" upper="2.6" effort="10.0" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Left forearm -->
  <link name="left_forearm">
    <visual>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.025 0.11"/>
      </geometry>
      <material name="blue_arm"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.025 0.11"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0"
               iyy="0.0002" iyz="0.0" izz="0.00003"/>
    </inertial>
  </link>

  <joint name="left_elbow_pitch" type="revolute">
    <parent link="left_forearm_pivot"/>
    <child link="left_forearm"/>
    <origin xyz="0.0 0.0 0.025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="2.6" effort="8.0" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Left wrist pivot -->
  <link name="left_wrist_pivot">
    <visual>
      <geometry>
        <cylinder radius="0.018" length="0.020"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.018" length="0.020"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.04"/>
      <inertia ixx="0.00003" ixy="0.0" ixz="0.0"
               iyy="0.00003" iyz="0.0" izz="0.00003"/>
    </inertial>
  </link>

  <joint name="left_wrist_pitch" type="revolute">
    <parent link="left_forearm"/>
    <child link="left_wrist_pivot"/>
    <origin xyz="0.0 0.0 0.11" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="2.6" effort="5.0" velocity="3.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <!-- Left hand -->
  <link name="left_hand">
    <visual>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.03 0.04"/>
      </geometry>
      <material name="blue_arm"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.03 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <mass value="0.06"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0"
               iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="left_wrist_roll" type="revolute">
    <parent link="left_wrist_pivot"/>
    <child link="left_hand"/>
    <origin xyz="0.0 0.0 0.020" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.6" upper="2.6" effort="5.0" velocity="3.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <!-- Left gripper -->
  <link name="left_gripper">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.01 0.03"/>
      </geometry>
      <material name="red_gripper">
        <color rgba="0.8 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.01 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="left_gripper_joint" type="prismatic">
    <parent link="left_hand"/>
    <child link="left_gripper"/>
    <origin xyz="0.0 0.0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.04" effort="5.0" velocity="0.5"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- ============================================================ -->
  <!-- RIGHT ARM                                                     -->
  <!-- ============================================================ -->

  <!-- Right arm mount -->
  <link name="right_arm_mount">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="right_base_rotation" type="revolute">
    <parent link="base_link"/>
    <child link="right_arm_mount"/>
    <origin xyz="0.0 -0.09 0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.6" upper="2.6" effort="10.0" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Right upper arm -->
  <link name="right_upper_arm">
    <visual>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.13"/>
      </geometry>
      <material name="orange_arm">
        <color rgba="0.8 0.4 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.13"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.0003" ixy="0.0" ixz="0.0"
               iyy="0.0003" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="right_shoulder_pitch" type="revolute">
    <parent link="right_arm_mount"/>
    <child link="right_upper_arm"/>
    <origin xyz="0.0 0.0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="2.6" effort="10.0" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Right forearm pivot link -->
  <link name="right_forearm_pivot">
    <visual>
      <geometry>
        <cylinder radius="0.020" length="0.025"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.020" length="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0"
               iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="right_shoulder_roll" type="revolute">
    <parent link="right_upper_arm"/>
    <child link="right_forearm_pivot"/>
    <origin xyz="0.0 0.0 0.13" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.6" upper="2.6" effort="10.0" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Right forearm -->
  <link name="right_forearm">
    <visual>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.025 0.11"/>
      </geometry>
      <material name="orange_arm"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.025 0.11"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.055" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0"
               iyy="0.0002" iyz="0.0" izz="0.00003"/>
    </inertial>
  </link>

  <joint name="right_elbow_pitch" type="revolute">
    <parent link="right_forearm_pivot"/>
    <child link="right_forearm"/>
    <origin xyz="0.0 0.0 0.025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="2.6" effort="8.0" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Right wrist pivot -->
  <link name="right_wrist_pivot">
    <visual>
      <geometry>
        <cylinder radius="0.018" length="0.020"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.018" length="0.020"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.04"/>
      <inertia ixx="0.00003" ixy="0.0" ixz="0.0"
               iyy="0.00003" iyz="0.0" izz="0.00003"/>
    </inertial>
  </link>

  <joint name="right_wrist_pitch" type="revolute">
    <parent link="right_forearm"/>
    <child link="right_wrist_pivot"/>
    <origin xyz="0.0 0.0 0.11" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="2.6" effort="5.0" velocity="3.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <!-- Right hand -->
  <link name="right_hand">
    <visual>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.03 0.04"/>
      </geometry>
      <material name="orange_arm"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.03 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <mass value="0.06"/>
      <inertia ixx="0.00005" ixy="0.0" ixz="0.0"
               iyy="0.00005" iyz="0.0" izz="0.00005"/>
    </inertial>
  </link>

  <joint name="right_wrist_roll" type="revolute">
    <parent link="right_wrist_pivot"/>
    <child link="right_hand"/>
    <origin xyz="0.0 0.0 0.020" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.6" upper="2.6" effort="5.0" velocity="3.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>

  <!-- Right gripper -->
  <link name="right_gripper">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.01 0.03"/>
      </geometry>
      <material name="red_gripper"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.01 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0"
               iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="right_gripper_joint" type="prismatic">
    <parent link="right_hand"/>
    <child link="right_gripper"/>
    <origin xyz="0.0 0.0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.04" effort="5.0" velocity="0.5"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

</robot>
